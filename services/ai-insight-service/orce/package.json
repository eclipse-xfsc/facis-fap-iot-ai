{
  "name": "facis-orce-ai-insight-runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Manifest of Node-RED contribs and npm modules required by the AI Insight ORCE runtime. Runtime installation happens in Dockerfile staging + entrypoint bootstrap.",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {},
  "scripts": {
    "test:flows": "node --test tests/flows/*.spec.js",
    "test:flows:coverage": "c8 --all --exclude \"node_modules/**\" --include \"tests/flows/helpers/**/*.js\" --reporter text --reporter lcov --check-coverage --lines 90 --functions 90 --branches 90 --statements 90 node --experimental-test-coverage --test tests/flows/*.spec.js"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "node-red-node-test-helper": "^0.3.4"
  }
}
