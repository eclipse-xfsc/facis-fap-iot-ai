# FACIS AI Insight Service environment template.
# This file documents accepted values, defaults, and behavior for each variable.
# Copy to `.env` for local development. Do not commit real credentials.

# ---- Runtime environment selector ----
# FACIS_ENV
# - Accepted values: any name that maps to config/<value>.yaml (e.g. development/test/production).
# - Used for: selecting environment-specific YAML config overlay.
FACIS_ENV=development

# ---- Service metadata ----
# AI_INSIGHT_SERVICE__NAME
# - Accepted values: non-empty string.
# - Used for: service identity metadata.
AI_INSIGHT_SERVICE__NAME=ai-insight-service

# AI_INSIGHT_SERVICE__ENVIRONMENT
# - Accepted values: non-empty string (e.g. development/test/production).
# - Used for: runtime environment semantics (for example dev-only response metadata behavior).
AI_INSIGHT_SERVICE__ENVIRONMENT=development

# ---- HTTP API server ----
# AI_INSIGHT_HTTP__HOST
# - Accepted values: bind address string (e.g. 0.0.0.0, 127.0.0.1).
# - Used for: API bind host.
AI_INSIGHT_HTTP__HOST=0.0.0.0

# AI_INSIGHT_HTTP__PORT
# - Accepted values: integer 1..65535.
# - Used for: API bind port.
AI_INSIGHT_HTTP__PORT=8080

# ---- Logging ----
# AI_INSIGHT_LOGGING__LEVEL
# - Accepted values: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# - Used for: log verbosity.
AI_INSIGHT_LOGGING__LEVEL=INFO

# AI_INSIGHT_LOGGING__FORMAT
# - Accepted values: Python logging format string.
# - Used for: log output format.
AI_INSIGHT_LOGGING__FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ---- Provider-agnostic LLM client ----
# AI_INSIGHT_LLM__API_KEY
# - Accepted values: provider API key string; can be empty if auth is not required by upstream.
# - Used for: authenticating LLM requests.
AI_INSIGHT_LLM__API_KEY=

# AI_INSIGHT_LLM__MODEL
# - Accepted values: model identifier supported by your provider.
# - Used for: selecting the LLM model (optional if provider routes only by URL).
AI_INSIGHT_LLM__MODEL=gpt-4.1-mini

# AI_INSIGHT_LLM__CHAT_COMPLETIONS_URL
# - Accepted values: full HTTPS chat completions URL for your provider, including query params.
# - Example (Azure): https://<resource>.cognitiveservices.azure.com/openai/deployments/<deployment>/chat/completions?api-version=2025-01-01-preview
# - Used for: direct request endpoint routing.
AI_INSIGHT_LLM__CHAT_COMPLETIONS_URL=

# AI_INSIGHT_LLM__TIMEOUT_SECONDS
# - Accepted values: integer 1..300.
# - Used for: LLM request timeout.
AI_INSIGHT_LLM__TIMEOUT_SECONDS=30

# AI_INSIGHT_LLM__MAX_RETRIES
# - Accepted values: integer 0..10.
# - Used for: retry attempts on retryable upstream failures.
AI_INSIGHT_LLM__MAX_RETRIES=3

# AI_INSIGHT_LLM__RETRY_BASE_DELAY_SECONDS
# - Accepted values: float >0 and <=10.
# - Used for: exponential backoff base delay.
AI_INSIGHT_LLM__RETRY_BASE_DELAY_SECONDS=0.5

# AI_INSIGHT_LLM__RETRY_MAX_DELAY_SECONDS
# - Accepted values: float >0 and <=60.
# - Used for: maximum retry backoff delay.
AI_INSIGHT_LLM__RETRY_MAX_DELAY_SECONDS=8.0

# AI_INSIGHT_LLM__REQUIRE_HTTPS
# - Accepted values: boolean true/false (also 1/0, yes/no, on/off).
# - Used for: rejecting insecure chat-completions URLs when true.
AI_INSIGHT_LLM__REQUIRE_HTTPS=true

# ---- Trino connection and OIDC auth (oidc_password_jwt) ----
# AI_INSIGHT_TRINO__HOST
# - Accepted values: hostname or IP.
# - Used for: Trino coordinator host.
AI_INSIGHT_TRINO__HOST=localhost

# AI_INSIGHT_TRINO__PORT
# - Accepted values: integer 1..65535.
# - Used for: Trino coordinator port.
AI_INSIGHT_TRINO__PORT=8080

# AI_INSIGHT_TRINO__USER
# - Accepted values: non-empty string.
# - Used for: Trino session user.
AI_INSIGHT_TRINO__USER=trino

# AI_INSIGHT_TRINO__OIDC_TOKEN_URL
# - Accepted values: OIDC token endpoint URL.
# - Used for: password-flow token exchange before Trino queries.
AI_INSIGHT_TRINO__OIDC_TOKEN_URL=

# AI_INSIGHT_TRINO__OIDC_CLIENT_ID
# - Accepted values: non-empty string.
# - Used for: OIDC client id.
AI_INSIGHT_TRINO__OIDC_CLIENT_ID=

# AI_INSIGHT_TRINO__OIDC_CLIENT_SECRET
# - Accepted values: non-empty string.
# - Used for: OIDC client secret.
AI_INSIGHT_TRINO__OIDC_CLIENT_SECRET=

# AI_INSIGHT_TRINO__OIDC_USERNAME
# - Accepted values: non-empty string.
# - Used for: OIDC password-flow username.
AI_INSIGHT_TRINO__OIDC_USERNAME=

# AI_INSIGHT_TRINO__OIDC_PASSWORD
# - Accepted values: non-empty string.
# - Used for: OIDC password-flow password.
AI_INSIGHT_TRINO__OIDC_PASSWORD=

# AI_INSIGHT_TRINO__OIDC_SCOPE
# - Accepted values: scope string (commonly "openid").
# - Used for: scope requested in token exchange.
AI_INSIGHT_TRINO__OIDC_SCOPE=openid

# AI_INSIGHT_TRINO__OIDC_VERIFY
# - Accepted values: boolean true/false or CA bundle path.
# - Used for: TLS verification for OIDC token endpoint only.
AI_INSIGHT_TRINO__OIDC_VERIFY=true

# AI_INSIGHT_TRINO__TARGET_SCHEMA
# - Accepted values: schema name string.
# - Used for: analytics source schema qualification (typically "gold").
AI_INSIGHT_TRINO__TARGET_SCHEMA=gold

# AI_INSIGHT_TRINO__TABLE_NET_GRID_HOURLY
# - Accepted values: table/view name string.
# - Used for: net grid base dataset source.
AI_INSIGHT_TRINO__TABLE_NET_GRID_HOURLY=net_grid_hourly

# AI_INSIGHT_TRINO__TABLE_EVENT_IMPACT_DAILY
# - Accepted values: table/view name string.
# - Used for: event impact source.
AI_INSIGHT_TRINO__TABLE_EVENT_IMPACT_DAILY=event_impact_daily

# AI_INSIGHT_TRINO__TABLE_STREETLIGHT_ZONE_HOURLY
# - Accepted values: table/view name string.
# - Used for: streetlight source in city status flow.
AI_INSIGHT_TRINO__TABLE_STREETLIGHT_ZONE_HOURLY=streetlight_zone_hourly

# AI_INSIGHT_TRINO__TABLE_WEATHER_HOURLY
# - Accepted values: table/view name string.
# - Used for: weather source in energy summary flow.
AI_INSIGHT_TRINO__TABLE_WEATHER_HOURLY=weather_hourly

# AI_INSIGHT_TRINO__TABLE_ENERGY_COST_DAILY
# - Accepted values: table/view name string.
# - Used for: daily energy cost source.
AI_INSIGHT_TRINO__TABLE_ENERGY_COST_DAILY=energy_cost_daily

# AI_INSIGHT_TRINO__TABLE_PV_SELF_CONSUMPTION_DAILY
# - Accepted values: table/view name string.
# - Used for: daily PV self-consumption source.
AI_INSIGHT_TRINO__TABLE_PV_SELF_CONSUMPTION_DAILY=pv_self_consumption_daily

# AI_INSIGHT_TRINO__CATALOG
# - Accepted values: catalog name available in Trino cluster.
# - Used for: Trino session catalog.
AI_INSIGHT_TRINO__CATALOG=hive

# AI_INSIGHT_TRINO__SCHEMA
# - Accepted values: schema name string.
# - Used for: default Trino session schema.
AI_INSIGHT_TRINO__SCHEMA=default

# AI_INSIGHT_TRINO__HTTP_SCHEME
# - Accepted values: http or https.
# - Used for: Trino transport protocol.
AI_INSIGHT_TRINO__HTTP_SCHEME=http

# AI_INSIGHT_TRINO__VERIFY
# - Accepted values: boolean true/false or CA bundle path.
# - Used for: TLS verification for Trino requests.
AI_INSIGHT_TRINO__VERIFY=true
# Example custom CA bundle:
# AI_INSIGHT_TRINO__VERIFY=/app/certs/trino-ca.crt

# AI_INSIGHT_TRINO__REQUEST_TIMEOUT_SECONDS
# - Accepted values: integer 1..300.
# - Used for: Trino request timeout.
AI_INSIGHT_TRINO__REQUEST_TIMEOUT_SECONDS=120

# ---- Policy enforcement ----
# AI_INSIGHT_POLICY__ENABLED
# - Accepted values: boolean.
# - Used for: enabling/disabling access policy checks.
AI_INSIGHT_POLICY__ENABLED=true

# AI_INSIGHT_POLICY__AGREEMENT_HEADER
# - Accepted values: HTTP header name.
# - Used for: agreement id extraction.
AI_INSIGHT_POLICY__AGREEMENT_HEADER=x-agreement-id

# AI_INSIGHT_POLICY__ASSET_HEADER
# - Accepted values: HTTP header name.
# - Used for: asset id extraction.
AI_INSIGHT_POLICY__ASSET_HEADER=x-asset-id

# AI_INSIGHT_POLICY__ROLE_HEADER
# - Accepted values: HTTP header name.
# - Used for: role extraction.
AI_INSIGHT_POLICY__ROLE_HEADER=x-user-roles

# AI_INSIGHT_POLICY__REQUIRED_ROLES
# - Accepted values: JSON array of strings.
# - Used for: required roles gate.
AI_INSIGHT_POLICY__REQUIRED_ROLES=["ai_insight_consumer"]

# AI_INSIGHT_POLICY__ALLOWED_AGREEMENT_IDS
# - Accepted values: JSON array of strings (empty array means unrestricted list).
# - Used for: optional allow-list by agreement id.
AI_INSIGHT_POLICY__ALLOWED_AGREEMENT_IDS=[]

# AI_INSIGHT_POLICY__ALLOWED_ASSET_IDS
# - Accepted values: JSON array of strings (empty array means unrestricted list).
# - Used for: optional allow-list by asset id.
AI_INSIGHT_POLICY__ALLOWED_ASSET_IDS=[]

# ---- Rate limiting ----
# AI_INSIGHT_RATE_LIMIT__ENABLED
# - Accepted values: boolean.
# - Used for: enabling per-agreement throttling.
AI_INSIGHT_RATE_LIMIT__ENABLED=true

# AI_INSIGHT_RATE_LIMIT__REQUESTS_PER_MINUTE
# - Accepted values: integer 1..10000.
# - Used for: maximum requests/minute per agreement id.
AI_INSIGHT_RATE_LIMIT__REQUESTS_PER_MINUTE=10

# ---- Cache ----
# AI_INSIGHT_CACHE__ENABLED
# - Accepted values: boolean.
# - Used for: enabling/disabling response cache.
AI_INSIGHT_CACHE__ENABLED=false

# AI_INSIGHT_CACHE__BACKEND
# - Accepted values: backend id string (currently "redis").
# - Used for: selecting cache implementation.
AI_INSIGHT_CACHE__BACKEND=redis

# AI_INSIGHT_CACHE__REDIS_URL
# - Accepted values: redis:// URL (empty allowed when cache disabled).
# - Used for: Redis connection endpoint.
AI_INSIGHT_CACHE__REDIS_URL=

# AI_INSIGHT_CACHE__TTL_SECONDS
# - Accepted values: integer 1..86400.
# - Used for: cache expiration time.
AI_INSIGHT_CACHE__TTL_SECONDS=300

# AI_INSIGHT_CACHE__KEY_PREFIX
# - Accepted values: non-empty string.
# - Used for: namespace prefix for cache keys.
AI_INSIGHT_CACHE__KEY_PREFIX=ai-insight:cache:v1

# AI_INSIGHT_CACHE__CONNECT_TIMEOUT_SECONDS
# - Accepted values: float >0 and <=30.
# - Used for: Redis connection timeout.
AI_INSIGHT_CACHE__CONNECT_TIMEOUT_SECONDS=1.0

# ---- Audit logging ----
# AI_INSIGHT_AUDIT__ENABLED
# - Accepted values: boolean.
# - Used for: enabling/disabling audit events.
AI_INSIGHT_AUDIT__ENABLED=true

# AI_INSIGHT_AUDIT__LOG_PROMPTS
# - Accepted values: boolean.
# - Used for: logging LLM prompts to audit logger.
AI_INSIGHT_AUDIT__LOG_PROMPTS=true

# AI_INSIGHT_AUDIT__LOG_RESPONSES
# - Accepted values: boolean.
# - Used for: logging LLM responses to audit logger.
AI_INSIGHT_AUDIT__LOG_RESPONSES=true

# AI_INSIGHT_AUDIT__LOGGER_NAME
# - Accepted values: Python logger name.
# - Used for: selecting logger namespace for audit messages.
AI_INSIGHT_AUDIT__LOGGER_NAME=src.audit

# ---- External prompt templates ----
# AI_INSIGHT_PROMPT_TEMPLATES__ENABLED
# - Accepted values: boolean.
# - Used for: enabling filesystem-based prompt templates.
AI_INSIGHT_PROMPT_TEMPLATES__ENABLED=false

# AI_INSIGHT_PROMPT_TEMPLATES__PATH
# - Accepted values: valid directory path.
# - Used for: loading prompt templates when externalization is enabled.
AI_INSIGHT_PROMPT_TEMPLATES__PATH=/app/config/prompts

