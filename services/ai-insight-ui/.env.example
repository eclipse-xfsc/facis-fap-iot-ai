# ============================================================
# FACIS AI Insight UI — ORCE Runtime Environment Variables
# ============================================================
# These variables are injected into the ORCE (Node-RED) container
# and used by the Node-RED flows at runtime.
#
# Copy to .env and fill in your values. Do not commit real credentials.
#
# For Vite build-time variables (Vue.js frontend), see ui/app/.env.example
# ============================================================

# --- AI Insight Service Backend ---
# AI_INSIGHT_BASE_URL
# - Accepted values: HTTP/HTTPS URL to AI Insight Service
# - Used for: All Tab 1 (AI Insight Proxy) requests: energy-summary, anomaly-report, city-status, latest insights
# - Default (cluster): http://ai-insight-service:8080
# - Default (local dev): http://localhost:8080
AI_INSIGHT_BASE_URL=http://ai-insight-service:8080

# --- Keycloak / OIDC ---
# FACIS_KEYCLOAK_URL
# - Accepted values: Keycloak OIDC token endpoint URL
# - Used for: OIDC password-grant token exchange (Tab 3: Trino Query, Tab 2: LLM Router)
# - Example: https://identity.facis.cloud/realms/facis/protocol/openid-connect/token
# - Required: Yes (if Trino auth or Keycloak-backed LLM auth is enabled)
FACIS_KEYCLOAK_URL=https://identity.facis.cloud/realms/facis/protocol/openid-connect/token

# FACIS_OIDC_CLIENT_ID
# - Accepted values: Non-empty string; must be registered in Keycloak with password grant enabled
# - Used for: OIDC client identifier in password-grant flow
# - Default: trino (service account for Trino SQL access)
# - Required: Yes (if using Keycloak for Trino auth)
FACIS_OIDC_CLIENT_ID=trino

# FACIS_OIDC_CLIENT_SECRET
# - Accepted values: Non-empty string; credential for OIDC client
# - Used for: OIDC client secret in password-grant authentication
# - Required: Yes (if using Keycloak)
# - Sensitive: Do not commit to version control
FACIS_OIDC_CLIENT_SECRET=<your-oidc-client-secret>

# --- Trino / Gold Layer ---
# FACIS_TRINO_HOST
# - Accepted values: Hostname or IP address of Trino coordinator
# - Used for: Trino SQL query endpoint (Tab 3: Trino Query flow)
# - Default (cluster): trino.stackable.svc.cluster.local
# - Default (local dev): localhost or 212.132.83.150 (if external)
# - Example: trino.stackable.svc.cluster.local or 212.132.83.150
FACIS_TRINO_HOST=trino.stackable.svc.cluster.local

# FACIS_TRINO_PORT
# - Accepted values: Integer 1..65535; typically 8080 (HTTP dev) or 8443 (HTTPS cluster)
# - Used for: Trino coordinator port for SQL queries
# - Default (dev): 8080
# - Default (cluster HTTPS): 8443
# - Note: Must match Trino's actual HTTP(S) port
FACIS_TRINO_PORT=8443

# FACIS_TRINO_USER
# - Accepted values: Non-empty string; Trino session username
# - Used for: OIDC password-grant username for Trino service-account authentication
# - Example: admin, facis, or a dedicated service account name
# - Required: Yes (for OIDC password-grant flow)
FACIS_TRINO_USER=facis

# FACIS_TRINO_PASSWORD
# - Accepted values: Non-empty string; Trino service account password
# - Used for: OIDC password-grant password
# - Required: Yes (for OIDC password-grant flow)
# - Sensitive: Do not commit to version control
FACIS_TRINO_PASSWORD=<your-trino-password>

# --- OpenAI (LLM Provider) ---
# FACIS_OPENAI_API_KEY
# - Accepted values: Non-empty string; OpenAI API key
# - Used for: Tab 2 (LLM Router) OpenAI path; freeform LLM queries
# - Example: sk-proj-xxxxxxxxxxxxxxxxxxxxx
# - Required: If enabling OpenAI as an LLM provider option
# - Sensitive: Do not commit to version control
FACIS_OPENAI_API_KEY=<your-openai-api-key>

# FACIS_OPENAI_MODEL
# - Accepted values: Valid OpenAI model identifier
# - Used for: Model selection for OpenAI API requests
# - Default: gpt-4.1-mini
# - Examples: gpt-4, gpt-4-turbo, gpt-3.5-turbo
# - Note: Verify the model is available in your OpenAI account
FACIS_OPENAI_MODEL=gpt-4.1-mini

# --- Anthropic Claude (LLM Provider) ---
# FACIS_ANTHROPIC_API_KEY
# - Accepted values: Non-empty string; Anthropic API key
# - Used for: Tab 2 (LLM Router) Claude path; freeform LLM queries
# - Example: sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# - Required: If enabling Claude as an LLM provider option
# - Sensitive: Do not commit to version control
FACIS_ANTHROPIC_API_KEY=<your-anthropic-api-key>

# FACIS_ANTHROPIC_MODEL
# - Accepted values: Valid Anthropic model identifier
# - Used for: Model selection for Claude API requests
# - Default: claude-sonnet-4-20250514
# - Examples: claude-opus, claude-sonnet, claude-haiku
# - Note: Verify the model is available in your Anthropic account
FACIS_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- Custom LLM (OpenAI-Compatible Provider) ---
# FACIS_CUSTOM_LLM_URL
# - Accepted values: Full HTTP/HTTPS URL to OpenAI-compatible chat completions endpoint
# - Used for: Tab 2 (LLM Router) custom provider path; alternative to OpenAI/Claude
# - Examples:
#   - Local Ollama: http://localhost:11434/v1/chat/completions
#   - Azure OpenAI: https://myresource.openai.azure.com/openai/deployments/mymodel/chat/completions?api-version=2025-01-01-preview
#   - Custom inference server: https://llm.internal.example.com/v1/chat/completions
# - Required: Only if using a custom LLM endpoint
# - Note: Leave empty to disable custom LLM option
FACIS_CUSTOM_LLM_URL=

# FACIS_CUSTOM_LLM_KEY
# - Accepted values: API key or token string (if required by custom endpoint)
# - Used for: Authorization header (Bearer token) for custom LLM requests
# - Required: Only if custom LLM endpoint requires authentication
# - Sensitive: Do not commit to version control
FACIS_CUSTOM_LLM_KEY=

# FACIS_CUSTOM_LLM_MODEL
# - Accepted values: Model identifier recognized by custom LLM endpoint
# - Used for: Model field in chat completions request payload
# - Example: ollama-mistral, my-custom-model
# - Required: If using custom LLM
# - Note: Verify the model is available on your custom endpoint
FACIS_CUSTOM_LLM_MODEL=custom-model

# ============================================================
# NOTES FOR OPERATORS
# ============================================================
#
# 1. DEPLOYMENT CONTEXT (Cluster vs. Local Dev)
#    - Cluster: Use Kubernetes service DNS (e.g., ai-insight-service.facis.svc.cluster.local)
#    - Local dev: Use localhost or port-forwarding (e.g., http://localhost:8080)
#
# 2. TLS/HTTPS in Cluster
#    - Trino typically uses HTTPS on port 8443 in production
#    - Verify CA certificates are properly mounted (handled by Helm)
#    - OIDC endpoints should use HTTPS for security
#
# 3. LLM Provider Selection
#    - At least one LLM provider (OpenAI, Claude, or Custom) should be configured
#    - Users select provider from the UI dropdown in Tab 2 (LLM Router)
#    - If a provider is not configured, attempting to use it will return an error
#
# 4. OIDC Token Expiry
#    - Keycloak tokens are typically short-lived (5-15 minutes)
#    - ORCE flows request new tokens per query
#    - If Trino queries timeout, check token refresh logic in Tab 3 flow
#
# 5. Gold Layer Queries
#    - Hardcoded tables in ORCE flows:
#      - hive.gold.net_grid_hourly
#      - hive.gold.event_impact_daily
#      - hive.gold.streetlight_zone_hourly
#      - hive.gold.weather_hourly
#    - Verify these tables exist in Trino before using freeform queries
#
# 6. Secret Management in Kubernetes
#    - Create secrets for sensitive values:
#      kubectl create secret generic orce-env-secrets \
#        --from-literal=openai-api-key=sk-... \
#        --from-literal=anthropic-api-key=sk-ant-... \
#        --from-literal=oidc-secret=... \
#        -n facis
#    - Reference in Helm values:
#      envFrom:
#        - secretRef:
#            name: orce-env-secrets
#
