# =============================================================================
# FACIS Cluster Credentials
# =============================================================================
# Copy to .env.cluster and fill in values:
#   cp .env.cluster.example .env.cluster
#
# Used by:
#   - scripts/setup_lakehouse.py   (create/teardown Bronze/Silver/Gold)
#   - scripts/validate_lakehouse.py (39-check WP3 validation)
#   - scripts/demo_lakehouse.py    (legacy data exploration)
#   - scripts/setup_nifi.py        (NiFi pipeline configuration)
#
# All scripts authenticate via Keycloak OIDC (password grant) to obtain
# a JWT Bearer token for Trino access.
# =============================================================================

# ---------------------------------------------------------------------------
# Keycloak OIDC credentials
# ---------------------------------------------------------------------------
# Obtain from the Keycloak admin console at:
#   https://identity.facis.cloud/admin/master/console/#/facis/users
# The user must have access to the 'facis' realm.

# Username for Keycloak OIDC authentication (realm: facis)
FACIS_OIDC_USERNAME=<test-user>

# Password for the above user
FACIS_OIDC_PASSWORD=<password>

# OIDC client secret for the 'OIDC' confidential client
# Obtain from: Keycloak → facis realm → Clients → OIDC → Credentials tab
FACIS_OIDC_CLIENT_SECRET=<client-secret>

# ---------------------------------------------------------------------------
# Service endpoints
# ---------------------------------------------------------------------------
# Override these if your cluster runs at a different address.
# The defaults below match the FACIS demo cluster.

# Keycloak base URL (realm token endpoint is derived automatically)
# Default: https://identity.facis.cloud
FACIS_KEYCLOAK_URL=https://identity.facis.cloud

# Trino coordinator hostname (HTTPS, port 8443)
# Default: 212.132.83.150
FACIS_TRINO_HOST=212.132.83.150

# Trino HTTPS port
# Default: 8443
FACIS_TRINO_PORT=8443

# Trino catalog name (Iceberg connector on S3)
# Default: fap-iotai-stackable
FACIS_TRINO_CATALOG=fap-iotai-stackable

# ---------------------------------------------------------------------------
# NiFi ingestion pipeline (used by setup_nifi.py)
# ---------------------------------------------------------------------------

# NiFi REST API URL (external access from workstation)
# Default: https://212.132.83.82:8443
FACIS_NIFI_URL=https://212.132.83.82:8443

# Trino Basic Auth credentials (used by NiFi InvokeHTTP processors)
# These come from the trino-users K8s secret in the Stackable namespace.
# Obtain from: kubectl get secret trino-users -n stackable -o jsonpath='{.data.admin}' | base64 -d
FACIS_TRINO_USER=admin
FACIS_TRINO_PASSWORD=<trino-basic-auth-password>
