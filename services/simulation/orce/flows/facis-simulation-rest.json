  {
    "id": "fn-rest-meter-by-id",
    "type": "function",
    "z": "tab-rest",
    "name": "meter by id",
    "func": "const meterId = msg.req.params.meter_id;\nconst meters = flow.get('latest_meters') || [];\nconst found = meters.find((m) => m.meter_id === meterId);\nif (!found) {\n    msg.statusCode = 404;\n    msg.payload = { error: 'meter not found', meter_id: meterId };\n} else {\n    msg.statusCode = 200;\n    msg.payload = found;\n}\nreturn msg;\n",
    "outputs": 1,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 460,
    "y": 200,
    "wires": [
      [
        "http-rest-response"
      ]
    ]
  },
