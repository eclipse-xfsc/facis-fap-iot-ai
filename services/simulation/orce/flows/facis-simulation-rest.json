  {
    "id": "fn-rest-health",
    "type": "function",
    "z": "tab-rest",
    "name": "health",
    "func": "const engine = flow.get('engine') || { state: 'initialized' };\nmsg.payload = {\n    status: 'ok',\n    state: engine.state,\n    simulation_time: engine.simulation_time,\n    last_envelope_at: flow.get('last_kafka_tick') || flow.get('last_mqtt_tick') || null,\n    runtime: 'orce-native'\n};\nmsg.statusCode = 200;\nreturn msg;\n",
    "outputs": 1,
    "timeout": "",
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 460,
    "y": 80,
    "wires": [
      [
        "http-rest-response"
      ]
    ]
  },
