[
    {
        "id": "tab-kafka-adapter",
        "type": "tab",
        "label": "FACIS Simulation \u2014 Kafka Adapter",
        "disabled": false,
        "info": "ORCE-native Kafka adapter for the simulation runtime.\n\nReceives the unified tick envelope from the Feeds tab via\n`sim.envelope` link-in, splits per feed type, and publishes to the\n9 Stackable-Kafka topics with mTLS.\n\nTopic conventions preserved from the legacy facis-simulation-cluster.json:\n  sim.smart_energy.{meter,pv,weather,price,consumer}\n  sim.smart_city.{light,traffic,event,weather}\n\nPrerequisite: node-red-contrib-rdkafka installed via the ORCE PVC\n(see services/simulation/orce/Dockerfile)."
    },
    {
        "id": "comment-kafka",
        "type": "comment",
        "z": "tab-kafka-adapter",
        "name": "ORCE-native Kafka adapter (envelope \u2192 9 topics)",
        "info": "Driven by the Feeds tab via link-in `sim.envelope`.\nTopic split + rdkafka producers identical to the legacy\nfacis-simulation-cluster.json HTTP-driven flow.",
        "x": 250,
        "y": 60,
        "wires": []
    },
    {
        "id": "kafka-broker-config",
        "type": "kafka-broker",
