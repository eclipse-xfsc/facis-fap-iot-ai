# =============================================================================
# FACIS Simulation Service — Environment Variables
# =============================================================================
# Copy to .env for local development: cp .env.example .env
#
# Prefix: SIMULATOR_ with __ (double underscore) for nested keys.
# Example: SIMULATOR_MQTT__HOST maps to config key mqtt.host
#
# See docs/guides/configuration.md for full reference.
# =============================================================================

# Environment selector — loads config/<value>.yaml overlay on top of default.yaml
# Options: development, production, test, cluster
FACIS_ENV=development

# --- Simulation Engine ---
SIMULATOR_SIMULATION__SEED=12345
SIMULATOR_SIMULATION__SPEED_FACTOR=1.0
SIMULATOR_SIMULATION__INTERVAL_MINUTES=1
SIMULATOR_SIMULATION__MODE=normal
# SIMULATOR_SIMULATION__START_TIME=2024-01-15T08:00:00Z  # null = current time

# --- HTTP REST API ---
SIMULATOR_HTTP__HOST=0.0.0.0
SIMULATOR_HTTP__PORT=8080

# --- Modbus TCP Server ---
SIMULATOR_MODBUS__HOST=0.0.0.0
SIMULATOR_MODBUS__PORT=502

# --- MQTT Publisher ---
SIMULATOR_MQTT__HOST=localhost
SIMULATOR_MQTT__PORT=1883
SIMULATOR_MQTT__CLIENT_ID=facis-simulator
SIMULATOR_MQTT__QOS=1

# --- Kafka Producer ---
SIMULATOR_KAFKA__ENABLED=true
SIMULATOR_KAFKA__BOOTSTRAP_SERVERS=localhost:9092
SIMULATOR_KAFKA__CLIENT_ID=facis-simulator
SIMULATOR_KAFKA__SECURITY_PROTOCOL=PLAINTEXT
# SIMULATOR_KAFKA__SSL_CA_LOCATION=
# SIMULATOR_KAFKA__SSL_CERTIFICATE_LOCATION=
# SIMULATOR_KAFKA__SSL_KEY_LOCATION=

# --- ORCE (Orchestration Engine) ---
SIMULATOR_ORCE__ENABLED=false
SIMULATOR_ORCE__URL=http://localhost:1880
SIMULATOR_ORCE__WEBHOOK_PATH=/api/sim/tick
SIMULATOR_ORCE__TIMEOUT_SECONDS=10.0

# --- Logging ---
SIMULATOR_LOGGING__LEVEL=INFO

# --- Structured JSON Logging ---
# LOG_FORMAT=json   # json (default in production) or text (local dev)
# LOG_LEVEL=INFO    # Override root log level
