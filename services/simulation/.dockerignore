.DS_Store
Thumbs.db

# CI/CD
.github/
.gitlab-ci.yml

# ORCE (separate service)
orce/

# Scripts (not needed in runtime)
scripts/

# TLS certs (mounted at runtime, never baked in)
certs/

# Data volume (runtime state)
data/
